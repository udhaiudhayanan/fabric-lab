{
    "name": "asset-transfer-basic",
    "version": "1.0.0",
    "description": "Asset Transfer Basic Application implemented in typeScript using fabric-gateway",
    "main": "dist/index.js",
    "typings": "dist/index.d.ts",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "build": "tsc",
        "build:watch": "tsc -w",
        "lint": "eslint src",
        "prepare": "npm run build",
        "pretest": "npm run lint",
        "start": "node dist/app.js"
    },
    "engineStrict": true,
    "author": "Hyperledger",
    "license": "Apache-2.0",
    "dependencies": {
        "@grpc/grpc-js": "^1.14.3",
        "@hyperledger/fabric-gateway": "^1.10.1",
        "body-parser": "^2.2.2",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "ts-node": "^10.9.2"
    },
    "devDependencies": {
        "@eslint/js": "^9.3.0",
        "@tsconfig/node18": "^18.2.2",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^18.18.6",
        "eslint": "^8.57.0",
        "typescript": "~5.4",
        "typescript-eslint": "^7.13.0"
    }
}
